#!/bin/bash
# =============================================================================
# SDLC Evidence Gate — Git Pre-Commit Hook
# =============================================================================
#
# Blocks commits that include source code changes unless SDLC agent evidence
# files exist in Documentation/sdlc-evidence/.
#
# Required evidence:
#   - ba-signoff.md  (BA agent validated requirements)
#   - qa-report.md   (QA agent executed tests and verified DoD)
#
# Bypass:
#   - echo "reason" > Documentation/sdlc-evidence/.bypass
#   - The bypass file is consumed (deleted) after one use
#
# Install:
#   git config core.hooksPath .githooks
# =============================================================================

set -euo pipefail

EVIDENCE_DIR="Documentation/sdlc-evidence"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No color

# ----------------------------------------------------------
# Check if any staged files are source code
# ----------------------------------------------------------
SOURCE_CODE_STAGED=false
DOC_GOVERNANCE_STAGED=false
FRONTEND_STAGED=false
FRONTEND_ONLY_SCSS=true
SCSS_STAGED=false
declare -a STAGED_SCSS_FILES=()

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
  # No staged files — allow (empty commit or amend)
  exit 0
fi

while IFS= read -r file; do
  if [[ "$file" == Documentation/design-system/* ]]; then
    DOC_GOVERNANCE_STAGED=true
  fi
  if [[ "$file" == Documentation/.Requirements/*/Design/R*-*.md ]]; then
    DOC_GOVERNANCE_STAGED=true
  fi
  if [[ "$file" == .githooks/pre-commit || "$file" == scripts/check-design-doc-governance.sh || "$file" == scripts/check-component-showcase-alignment.sh || "$file" == scripts/check-spacing-scale.sh || "$file" == scripts/frontend-governance.sh || "$file" == .github/workflows/ci.yml || "$file" == .github/workflows/frontend-strict-quality.yml || "$file" == .github/workflows/docs-quality.yml ]]; then
    DOC_GOVERNANCE_STAGED=true
  fi

  # Frontend source code
  if [[ "$file" == frontend/src/* ]]; then
    SOURCE_CODE_STAGED=true
    FRONTEND_STAGED=true
    if [[ "$file" =~ ^frontend/src/.+\.scss$ ]]; then
      SCSS_STAGED=true
      STAGED_SCSS_FILES+=("$file")
    else
      FRONTEND_ONLY_SCSS=false
    fi
    continue
  fi
  # Frontend E2E tests
  if [[ "$file" == frontend/e2e/* ]]; then
    SOURCE_CODE_STAGED=true
    FRONTEND_STAGED=true
    FRONTEND_ONLY_SCSS=false
    continue
  fi
  # Backend source code
  if [[ "$file" == backend/*/src/* ]]; then
    SOURCE_CODE_STAGED=true
    break
  fi
done <<< "$STAGED_FILES"

if [[ "$DOC_GOVERNANCE_STAGED" == "true" ]]; then
  echo "Running design documentation governance gate..."
  ./scripts/check-design-doc-governance.sh
  ./scripts/check-component-showcase-alignment.sh
fi

# No source code staged — allow freely (docs, config, etc.)
if [[ "$SOURCE_CODE_STAGED" == "false" ]]; then
  exit 0
fi

# ----------------------------------------------------------
# Check for bypass file (single-use)
# ----------------------------------------------------------
if [[ -f "$EVIDENCE_DIR/.bypass" ]]; then
  BYPASS_REASON=$(cat "$EVIDENCE_DIR/.bypass")
  echo -e "${YELLOW}SDLC bypass used:${NC} $BYPASS_REASON"
  rm -f "$EVIDENCE_DIR/.bypass"
  exit 0
fi

# ----------------------------------------------------------
# Check for required evidence files
# ----------------------------------------------------------
MISSING=()

if [[ ! -f "$EVIDENCE_DIR/ba-signoff.md" ]]; then
  MISSING+=("ba-signoff.md (BA agent requirements validation)")
fi

if [[ ! -f "$EVIDENCE_DIR/qa-report.md" ]]; then
  MISSING+=("qa-report.md (QA agent test execution report)")
fi

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo ""
  echo -e "${RED}============================================${NC}"
  echo -e "${RED}  COMMIT BLOCKED: Missing SDLC Evidence${NC}"
  echo -e "${RED}============================================${NC}"
  echo ""
  echo "Source code changes require agent evidence before commit."
  echo ""
  echo "Missing evidence files:"
  for item in "${MISSING[@]}"; do
    echo -e "  ${RED}✗${NC} $EVIDENCE_DIR/$item"
  done
  echo ""
  echo "Required workflow: BA agent → SA agent → DEV agent → QA agent"
  echo ""
  echo -e "Each agent creates its evidence file in ${YELLOW}$EVIDENCE_DIR/${NC}"
  echo ""
  echo "For trivial changes (typo fixes), create a bypass:"
  echo -e "  ${GREEN}echo \"reason\" > $EVIDENCE_DIR/.bypass${NC}"
  echo ""
  exit 1
fi

# All evidence present
echo -e "${GREEN}SDLC evidence verified:${NC} BA sign-off ✓ | QA report ✓"

if [[ "$SCSS_STAGED" == "true" ]]; then
  echo -e "${YELLOW}SCSS files changed${NC} — running staged non-regression checks..."
  bash scripts/check-staged-scss-non-regression.sh "${STAGED_SCSS_FILES[@]}"
  echo -e "${YELLOW}Running strict spacing drift check on staged SCSS files...${NC}"
  ./scripts/check-spacing-scale.sh --fail-on-warnings "${STAGED_SCSS_FILES[@]}"
  echo -e "${GREEN}File-scoped SCSS checks passed.${NC}"
fi

# ----------------------------------------------------------
# Frontend governance gate
# ----------------------------------------------------------
if [[ "$FRONTEND_STAGED" == "true" ]]; then
  if [[ "$FRONTEND_ONLY_SCSS" == "true" && "$SCSS_STAGED" == "true" ]]; then
    echo "Running frontend file-scoped build gate..."
    (cd frontend && npx ng build --configuration=development)
  else
    echo "Running frontend quality gate..."
    ./scripts/frontend-governance.sh
  fi
fi

exit 0
