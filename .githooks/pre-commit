#!/bin/bash
# =============================================================================
# SDLC Evidence Gate — Git Pre-Commit Hook
# =============================================================================
#
# Blocks commits that include source code changes unless SDLC agent evidence
# files exist in docs/sdlc-evidence/.
#
# Required evidence:
#   - ba-signoff.md  (BA agent validated requirements)
#   - qa-report.md   (QA agent executed tests and verified DoD)
#
# Bypass:
#   - echo "reason" > docs/sdlc-evidence/.bypass
#   - The bypass file is consumed (deleted) after one use
#
# Install:
#   git config core.hooksPath .githooks
# =============================================================================

set -euo pipefail

EVIDENCE_DIR="docs/sdlc-evidence"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No color

# ----------------------------------------------------------
# Check if any staged files are source code
# ----------------------------------------------------------
SOURCE_CODE_STAGED=false

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
  # No staged files — allow (empty commit or amend)
  exit 0
fi

while IFS= read -r file; do
  # Legacy frontend source code
  if [[ "$file" == frontendold/src/* ]]; then
    SOURCE_CODE_STAGED=true
    break
  fi
  # Frontend source code
  if [[ "$file" == frontend/src/* ]]; then
    SOURCE_CODE_STAGED=true
    break
  fi
  # Legacy frontend E2E tests
  if [[ "$file" == frontendold/e2e/* ]]; then
    SOURCE_CODE_STAGED=true
    break
  fi
  # Frontend E2E tests
  if [[ "$file" == frontend/e2e/* ]]; then
    SOURCE_CODE_STAGED=true
    break
  fi
  # Backend source code
  if [[ "$file" == backend/*/src/* ]]; then
    SOURCE_CODE_STAGED=true
    break
  fi
done <<< "$STAGED_FILES"

# No source code staged — allow freely (docs, config, etc.)
if [[ "$SOURCE_CODE_STAGED" == "false" ]]; then
  exit 0
fi

# ----------------------------------------------------------
# Check for bypass file (single-use)
# ----------------------------------------------------------
if [[ -f "$EVIDENCE_DIR/.bypass" ]]; then
  BYPASS_REASON=$(cat "$EVIDENCE_DIR/.bypass")
  echo -e "${YELLOW}SDLC bypass used:${NC} $BYPASS_REASON"
  rm -f "$EVIDENCE_DIR/.bypass"
  exit 0
fi

# ----------------------------------------------------------
# Check for required evidence files
# ----------------------------------------------------------
MISSING=()

if [[ ! -f "$EVIDENCE_DIR/ba-signoff.md" ]]; then
  MISSING+=("ba-signoff.md (BA agent requirements validation)")
fi

if [[ ! -f "$EVIDENCE_DIR/qa-report.md" ]]; then
  MISSING+=("qa-report.md (QA agent test execution report)")
fi

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo ""
  echo -e "${RED}============================================${NC}"
  echo -e "${RED}  COMMIT BLOCKED: Missing SDLC Evidence${NC}"
  echo -e "${RED}============================================${NC}"
  echo ""
  echo "Source code changes require agent evidence before commit."
  echo ""
  echo "Missing evidence files:"
  for item in "${MISSING[@]}"; do
    echo -e "  ${RED}✗${NC} $EVIDENCE_DIR/$item"
  done
  echo ""
  echo "Required workflow: BA agent → SA agent → DEV agent → QA agent"
  echo ""
  echo -e "Each agent creates its evidence file in ${YELLOW}$EVIDENCE_DIR/${NC}"
  echo ""
  echo "For trivial changes (typo fixes), create a bypass:"
  echo -e "  ${GREEN}echo \"reason\" > $EVIDENCE_DIR/.bypass${NC}"
  echo ""
  exit 1
fi

# All evidence present
echo -e "${GREEN}SDLC evidence verified:${NC} BA sign-off ✓ | QA report ✓"

# ----------------------------------------------------------
# Frontend governance gate
# ----------------------------------------------------------
FRONTEND_STAGED=false
while IFS= read -r file; do
  if [[ "$file" == frontend/* ]]; then
    FRONTEND_STAGED=true
    break
  fi
done <<< "$STAGED_FILES"

if [[ "$FRONTEND_STAGED" == "true" ]]; then
  echo "Running frontend quality gate..."
  ./scripts/frontend-governance.sh
fi

exit 0
