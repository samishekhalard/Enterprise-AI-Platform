# ============================================================================
# EMS Backend - Environment Variables
# Copy this file to .env and customize for your environment
# ============================================================================

# PostgreSQL
POSTGRES_DB=master_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Neo4j
NEO4J_AUTH=neo4j/your_secure_password_here

# Keycloak - Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_password_here
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=your_secure_password_here

# Keycloak - EMS Client (ems-auth-facade)
# Secret used by the auth-facade service to authenticate with Keycloak
KEYCLOAK_CLIENT_SECRET=ems-auth-facade-secret

# Keycloak - Superadmin User
# Initial password for the superadmin account (change on first login)
SUPERADMIN_PASSWORD=admin
# Set to "false" to disable forced password change on first login
SUPERADMIN_TEMP_PASSWORD=true

# Kafka (optional)
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
