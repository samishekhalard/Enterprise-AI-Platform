<?xml version="1.0" encoding="UTF-8"?>
<!--
  Apache Directory Studio Connection Configuration
  ================================================
  Connection: Forum Systems Public LDAP Test Server

  Import: File > Import > LDAP > Connection(s) from file

  Users (all password: "password"):
    tesla, einstein, newton, galileo, euler, gauss, riemann, curie

  Groups: mathematicians, scientists, chemists, italians
-->
<connections>
    <connection
        id="forumsys-public-ldap"
        name="Forum Systems Public LDAP"
        host="ldap.forumsys.com"
        port="389"
        encryptionMethod="0"
        authMethod="1"
        bindPrincipal="cn=read-only-admin,dc=example,dc=com"
        bindPassword="password"
        saslMechanism=""
        saslRealm=""
        saslQop="0"
        saslSecurityStrength="0"
        saslMutualAuthentication="false"
        readOnly="true"
        fetchBaseDNs="true"
        fetchSubentries="false"
        fetchOperationalAttributes="false"
        aliasesDereferencingMethod="1"
        referralsHandlingMethod="1"
        timeLimit="0"
        countLimit="0"
    >
        <extendedProperties>
            <extendedProperty key="connection.parameter.modifyMode" value="0"/>
            <extendedProperty key="connection.parameter.modifyModeNoEMR" value="0"/>
            <extendedProperty key="connection.parameter.modifyOrder" value="0"/>
        </extendedProperties>
    </connection>
</connections>
