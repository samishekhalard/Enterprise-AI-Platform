dn: uid=viewer,ou=users,dc=ems,dc=test
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
uid: viewer
cn: Test Viewer
sn: Viewer
givenName: Test
mail: viewer@ems.test
userPassword: ViewerPass1!
employeeNumber: EMS-V001
title: Viewer
l: Dubai
st: Dubai
postalCode: 00000

