# ==============================================================================
# EMSIST Test LDAP Directory — Seed Data
# ==============================================================================
# Organization: dc=ems,dc=test
# Admin bind:   cn=admin,dc=ems,dc=test / admin
#
# Structure:
#   dc=ems,dc=test
#   ├── ou=users           (user accounts)
#   ├── ou=groups           (role-based groups matching EMS role hierarchy)
#   ├── ou=service-accounts (service/system accounts)
#   └── ou=disabled         (disabled accounts for negative testing)
#
# Test Users:
#   viewer@ems.test      / ViewerPass1!     → VIEWER role
#   user@ems.test        / UserPass1!       → USER role
#   manager@ems.test     / ManagerPass1!    → MANAGER role
#   admin@ems.test       / AdminPass1!      → ADMIN role
#   superadmin@ems.test  / SuperAdminPass1! → SUPER_ADMIN role
#   multi.role@ems.test  / MultiPass1!      → USER + MANAGER (multi-group)
#   new.user@ems.test    / NewUserPass1!    → no group (for testing unassigned)
#   disabled@ems.test    / DisabledPass1!   → disabled account
# ==============================================================================

# ------------------------------------------------------------------------------
# Organizational Units
# ------------------------------------------------------------------------------
dn: ou=users,dc=ems,dc=test
objectClass: organizationalUnit
ou: users
description: EMS user accounts

dn: ou=groups,dc=ems,dc=test
objectClass: organizationalUnit
ou: groups
description: EMS role-based groups

dn: ou=service-accounts,dc=ems,dc=test
objectClass: organizationalUnit
ou: service-accounts
description: Service and system accounts

dn: ou=disabled,dc=ems,dc=test
objectClass: organizationalUnit
ou: disabled
description: Disabled/locked accounts for negative testing

# ------------------------------------------------------------------------------
# Groups (matching EMS role hierarchy: SUPER_ADMIN > ADMIN > MANAGER > USER > VIEWER)
# ------------------------------------------------------------------------------
dn: cn=VIEWER,ou=groups,dc=ems,dc=test
objectClass: groupOfNames
cn: VIEWER
description: EMS Viewer role group
member: uid=viewer,ou=users,dc=ems,dc=test

dn: cn=USER,ou=groups,dc=ems,dc=test
objectClass: groupOfNames
cn: USER
description: EMS User role group
member: uid=testuser,ou=users,dc=ems,dc=test
member: uid=multi.role,ou=users,dc=ems,dc=test

dn: cn=MANAGER,ou=groups,dc=ems,dc=test
objectClass: groupOfNames
cn: MANAGER
description: EMS Manager role group
member: uid=manager,ou=users,dc=ems,dc=test
member: uid=multi.role,ou=users,dc=ems,dc=test

dn: cn=ADMIN,ou=groups,dc=ems,dc=test
objectClass: groupOfNames
cn: ADMIN
description: EMS Admin role group
member: uid=admin.user,ou=users,dc=ems,dc=test

dn: cn=SUPER_ADMIN,ou=groups,dc=ems,dc=test
objectClass: groupOfNames
cn: SUPER_ADMIN
description: EMS Super Admin role group
member: uid=superadmin,ou=users,dc=ems,dc=test

# ------------------------------------------------------------------------------
# Users
# ------------------------------------------------------------------------------

