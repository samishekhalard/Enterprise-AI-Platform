# ==============================================================================
# EMSIST - Development Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file to the project root as .env.dev:
#        cp infrastructure/docker/.env.dev.template .env.dev
#   2. Replace all CHANGE_ME values with unique passwords.
#      Generate secure passwords with: openssl rand -base64 32
#   3. NEVER commit .env.dev to Git (it is gitignored).
#
# IMPORTANT: All passwords must be set. Services will fail to start if any
# password environment variable is missing (fail-fast, no fallback defaults).
#
# ADR: ADR-020 (Service Credential Management)
# Issues: INF-004, INF-010
# ==============================================================================

# ==============================================================================
# PostgreSQL Superuser (used ONLY for database initialization and admin tasks)
# ==============================================================================
POSTGRES_DB=master_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_dev_postgres_superuser

# ==============================================================================
# Per-Service PostgreSQL Passwords
# Each service connects with its OWN user -- never the superuser.
# User names are fixed (created by init-db.sh); only passwords are configurable.
# ==============================================================================

# tenant-service -> svc_tenant @ master_db
SVC_TENANT_PASSWORD=CHANGE_ME_dev_tenant_password

# user-service -> svc_user @ user_db
SVC_USER_PASSWORD=CHANGE_ME_dev_user_password

# license-service -> svc_license @ license_db
SVC_LICENSE_PASSWORD=CHANGE_ME_dev_license_password

# notification-service -> svc_notify @ notification_db
SVC_NOTIFICATION_PASSWORD=CHANGE_ME_dev_notification_password

# audit-service -> svc_audit @ audit_db (append-only: INSERT + SELECT)
SVC_AUDIT_PASSWORD=CHANGE_ME_dev_audit_password

# ai-service -> svc_ai @ ai_db
SVC_AI_PASSWORD=CHANGE_ME_dev_ai_password

# process-service -> svc_process @ process_db
SVC_PROCESS_PASSWORD=CHANGE_ME_dev_process_password

# keycloak -> kc_db_user @ keycloak_db
KC_DB_PASSWORD=CHANGE_ME_dev_keycloak_db_password

# ==============================================================================
# Keycloak Identity Provider
# ==============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_dev_keycloak_admin
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_dev_client_secret
SERVICE_CLIENT_ID=ems-auth-facade
SERVICE_CLIENT_SECRET=CHANGE_ME_dev_service_client_secret
SERVICE_TOKEN_SCOPE=internal.service
SUPERADMIN_PASSWORD=CHANGE_ME_dev_superadmin
SUPERADMIN_TEMP_PASSWORD=true

# ==============================================================================
# Neo4j (auth-facade graph database)
# ==============================================================================
NEO4J_AUTH=neo4j/CHANGE_ME_dev_neo4j_password
NEO4J_PASSWORD=CHANGE_ME_dev_neo4j_password

# ==============================================================================
# Jasypt Encryption (application.yml credential encryption)
# ==============================================================================
JASYPT_PASSWORD=CHANGE_ME_dev_jasypt_secret

# ==============================================================================
# Backup Configuration (backup-cron sidecar — ADR-018, ADR-019)
# ==============================================================================

# Number of days to retain backup files (dev default: 7)
BACKUP_RETENTION_DAYS=7

# age public key for encrypting backup archives.
# Generate: age-keygen -o ~/.age-key.txt  (keep private key OFFLINE)
# Leave empty to skip encryption (acceptable for dev; NOT for staging).
# Format: age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AGE_PUBLIC_KEY=

# ==============================================================================
# AI Service API Keys (optional -- leave empty to disable provider)
# ==============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
