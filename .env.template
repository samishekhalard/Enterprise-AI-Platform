# ==============================================================================
# EMSIST Production/Staging Environment Variables Template
#
# Copy this file to .env.prod or .env.staging and fill in all CHANGE_ME values.
# NEVER commit .env.prod or .env.staging to version control.
#
# Required secrets are marked with [SECRET] -- these MUST be changed.
# ==============================================================================

# ------------------------------------------------------------------------------
# Deployment
# ------------------------------------------------------------------------------
# Docker image version tag to deploy (set by CI/CD or deploy.sh)
IMAGE_TAG=latest

# Compose project name (avoids collisions on shared hosts)
COMPOSE_PROJECT_NAME=emsist-prod

# ------------------------------------------------------------------------------
# PostgreSQL  [SECRET]
# ------------------------------------------------------------------------------
POSTGRES_DB=master_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME                  # [SECRET] Root PostgreSQL password

# Per-service database passwords (created by init-db.sh)
SVC_TENANT_PASSWORD=CHANGE_ME               # [SECRET]
SVC_USER_PASSWORD=CHANGE_ME                 # [SECRET]
SVC_LICENSE_PASSWORD=CHANGE_ME              # [SECRET]
SVC_NOTIFICATION_PASSWORD=CHANGE_ME         # [SECRET]
SVC_AUDIT_PASSWORD=CHANGE_ME                # [SECRET]
SVC_AI_PASSWORD=CHANGE_ME                   # [SECRET]
SVC_PROCESS_PASSWORD=CHANGE_ME              # [SECRET]

# Keycloak database user password
KC_DB_PASSWORD=CHANGE_ME                    # [SECRET]

# ------------------------------------------------------------------------------
# Neo4j (auth-facade, definition-service)  [SECRET]
# ------------------------------------------------------------------------------
NEO4J_AUTH=neo4j/CHANGE_ME                  # [SECRET] Format: username/password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME                    # [SECRET] Must match NEO4J_AUTH password

# ------------------------------------------------------------------------------
# Keycloak (Identity Provider)  [SECRET]
# ------------------------------------------------------------------------------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=master
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME           # [SECRET]
KEYCLOAK_CLIENT_SECRET=CHANGE_ME            # [SECRET]
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/master
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/master/protocol/openid-connect/certs

# Service-to-service client credentials
SERVICE_CLIENT_ID=ems-auth-facade
SERVICE_CLIENT_SECRET=CHANGE_ME             # [SECRET]
SERVICE_TOKEN_SCOPE=internal.service
SERVICE_TOKEN_URL=http://keycloak:8080/realms/master/protocol/openid-connect/token

# Keycloak init sidecar
SUPERADMIN_PASSWORD=CHANGE_ME               # [SECRET]
SUPERADMIN_TEMP_PASSWORD=false

# Public URLs (used for Keycloak redirect URIs)
FRONTEND_PUBLIC_URL=https://ems.example.com
API_GATEWAY_PUBLIC_URL=https://api.ems.example.com

# ------------------------------------------------------------------------------
# Valkey (cache)
# ------------------------------------------------------------------------------
VALKEY_HOST=valkey
VALKEY_PORT=6379

# ------------------------------------------------------------------------------
# Kafka (event streaming)
# ------------------------------------------------------------------------------
KAFKA_ENABLED=true
KAFKA_SERVERS=kafka:29092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ------------------------------------------------------------------------------
# Mail (notification-service)
# ------------------------------------------------------------------------------
MAIL_HOST=mailhog
MAIL_PORT=1025

# ------------------------------------------------------------------------------
# Eureka (service registry)
# ------------------------------------------------------------------------------
EUREKA_ENABLED=true
EUREKA_URL=http://eureka:8761/eureka

# ------------------------------------------------------------------------------
# Security  [SECRET]
# ------------------------------------------------------------------------------
JASYPT_PASSWORD=CHANGE_ME                   # [SECRET] Jasypt encryption password

# ------------------------------------------------------------------------------
# AI Service (optional)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=                             # [SECRET] Leave empty to disable
ANTHROPIC_API_KEY=                          # [SECRET] Leave empty to disable
GEMINI_API_KEY=                             # [SECRET] Leave empty to disable

# ------------------------------------------------------------------------------
# Backup (backup-cron container)
# ------------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
AGE_PUBLIC_KEY=                             # [SECRET] age encryption public key
