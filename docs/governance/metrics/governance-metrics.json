{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance Metrics Data",
  "description": "Tracking data for governance metrics",
  "version": "1.0.0",
  "lastUpdated": "2026-02-25",

  "metadata": {
    "framework": "EMSIST SDLC Agent Governance",
    "measurementStart": "2026-02-25",
    "reviewCycle": "monthly"
  },

  "targets": {
    "principleCompliance": {
      "target": 95,
      "unit": "percent",
      "comparison": "greaterThanOrEqual"
    },
    "violationRate": {
      "target": 5,
      "unit": "countPerSprint",
      "comparison": "lessThan"
    },
    "improvementRate": {
      "target": 50,
      "unit": "percent",
      "comparison": "greaterThan"
    },
    "governanceHealth": {
      "target": "green",
      "thresholds": {
        "green": 90,
        "yellow": 70,
        "orange": 50,
        "red": 0
      }
    }
  },

  "agents": [
    "ARCH",
    "SA",
    "BA",
    "DEV",
    "DBA",
    "QA",
    "SEC",
    "DEVOPS",
    "DOC"
  ],

  "sprints": [],

