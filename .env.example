# ==============================================================================
# EMSIST Environment Variables Template
# Copy to `.env` (or `.env.dev` / `.env.staging`) and customize.
# Never commit real secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Compose / runtime
# ------------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=ems-dev
SERVER_PORT=
EUREKA_ENABLED=true
EUREKA_URL=http://eureka:8761/eureka

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_DB=master_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# Optional shared DB credentials (for services that read generic vars)
DATABASE_URL=
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME

# Service DB passwords (used in dev/staging compose)
SVC_TENANT_PASSWORD=CHANGE_ME
SVC_USER_PASSWORD=CHANGE_ME
SVC_LICENSE_PASSWORD=CHANGE_ME
SVC_NOTIFICATION_PASSWORD=CHANGE_ME
SVC_AUDIT_PASSWORD=CHANGE_ME
SVC_AI_PASSWORD=CHANGE_ME
SVC_PROCESS_PASSWORD=CHANGE_ME

# AI service DB-specific env names
DB_HOST=postgres
DB_PORT=5432
DB_NAME=master_db
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# ------------------------------------------------------------------------------
# Keycloak core + bootstrap
# ------------------------------------------------------------------------------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=master
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KC_DB_USERNAME=kc_db_user
KC_DB_PASSWORD=CHANGE_ME
KEYCLOAK_CLIENT_ID=ems-auth-facade
KEYCLOAK_CLIENT_SECRET=ems-auth-facade-secret
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/master
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/master/protocol/openid-connect/certs
SERVICE_CLIENT_ID=ems-auth-facade
SERVICE_CLIENT_SECRET=ems-auth-facade-secret
SERVICE_TOKEN_SCOPE=internal.service
SERVICE_TOKEN_URL=http://keycloak:8080/realms/master/protocol/openid-connect/token
SUPERADMIN_PASSWORD=CHANGE_ME
SUPERADMIN_TEMP_PASSWORD=true

# Public URLs for Keycloak bootstrap client redirect/web origins
FRONTEND_PUBLIC_URL=https://ems.example
API_GATEWAY_PUBLIC_URL=https://gateway.ems.example

# ------------------------------------------------------------------------------
# Cache / messaging / mail
# ------------------------------------------------------------------------------
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=
KAFKA_ENABLED=true
KAFKA_SERVERS=kafka:29092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@ems.local
MAIL_AUTH=false
MAIL_STARTTLS=false
EMAIL_ENABLED=true

# ------------------------------------------------------------------------------
# Neo4j (auth-facade)
# ------------------------------------------------------------------------------
NEO4J_AUTH=neo4j/CHANGE_ME
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ------------------------------------------------------------------------------
# Security / encryption
# ------------------------------------------------------------------------------
JASYPT_PASSWORD=CHANGE_ME

# ------------------------------------------------------------------------------
# AI providers and model toggles
# ------------------------------------------------------------------------------
OPENAI_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
GEMINI_ENABLED=false
GEMINI_API_KEY=
OLLAMA_ENABLED=false
OLLAMA_URL=http://host.docker.internal:11434

# ------------------------------------------------------------------------------
# External IdP provider settings (enable only if used)
# ------------------------------------------------------------------------------
AUTH_PROVIDER=keycloak
AUTH_BROKER_STORAGE=database

# Auth0
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# Okta
OKTA_DOMAIN=
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Azure AD / Microsoft
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Google
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------------------
# Backup / encryption settings
# ------------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
AGE_PUBLIC_KEY=
FLYWAY_REPAIR=false
