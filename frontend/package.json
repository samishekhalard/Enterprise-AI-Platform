{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "start:docker": "ng serve --configuration development --host 0.0.0.0 --port 4200 --ssl=false --proxy-config proxy.conf.docker.json",
    "build": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "lint": "ng lint",
    "start:direct": "ng serve --configuration development --host 0.0.0.0 --port 4200",
    "build:prod": "ng build --configuration production",
    "test:watch": "ng test",
    "e2e": "playwright test",
    "e2e:quality": "playwright test -c playwright.quality.config.ts",
    "e2e:quality:update-snapshots": "playwright test -c playwright.quality.config.ts --update-snapshots",
    "typecheck": "tsc --noEmit",
    "check:admin-style-tokens": "bash ../scripts/check-admin-style-tokens.sh",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "validate": "npm run format:check && npm run lint && npm run check:admin-style-tokens && npm run typecheck && npm run test && npm run build"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "jsdom": "^27.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  }
}
