      <bpmndi:BPMNShape id="DataObjectReference_LoginShell_di" bpmnElement="DataObjectReference_LoginShell">
        <dc:Bounds x="357" y="335" width="36" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreReference_TenantPgDatabase_di" bpmnElement="DataStoreReference_TenantPgDatabase">
        <dc:Bounds x="595" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>

