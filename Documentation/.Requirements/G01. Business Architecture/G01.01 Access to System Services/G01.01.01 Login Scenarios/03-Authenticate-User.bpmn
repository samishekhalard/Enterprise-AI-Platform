<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_AuthenticateUser"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.44.0">
  <bpmn:collaboration id="Collaboration_AuthenticateUser">
    <bpmn:participant id="Participant_AuthenticateUser" name="Authenticate user" processRef="Process_AuthenticateUser" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AuthenticateUser" name="J01 Authenticate User" isExecutable="false">
    <bpmn:documentation>Objective: authenticate user and authorize user to access the landing page. Success outcome: user authenticated and redirected to the system shell and landing page. Failure outcomes: tenant not found, tenant suspended, tenant license expired, tenant access blocked, no authentication methods, invalid credentials, authentication provider failure, invalid MFA code.</bpmn:documentation>
    <bpmn:extensionElements>
      <camunda:properties>
        <camunda:property name="journey_code" value="J01" />
        <camunda:property name="journey_name" value="Authenticate User" />
        <camunda:property name="primary_screen" value="SC01" />
        <camunda:property name="mfa_screen" value="SC02" />
        <camunda:property name="not_found_screen" value="SC03" />
      </camunda:properties>
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_AuthenticateUser">
      <bpmn:lane id="Lane_AuthenticateUser">
        <bpmn:flowNodeRef>Event_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_OpenLoginShell</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectTenant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_TenantSelected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ResolveTenantAuthMethods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TenantResolution</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_TenantNotFound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenTenantNotFoundShell</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TenantNotFound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_TenantSuspended</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowTenantSuspendedMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TenantSuspended</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_TenantLicenseExpired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowTenantLicenseExpiredMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TenantLicenseExpired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_NoAuthMethods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowNoAuthMethodsMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_NoAuthMethods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_TenantAccessBlocked</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowTenantAccessBlockedMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TenantAccessBlocked</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_AuthMethodsAvailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectAuthMethod</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AuthMethodType</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_CredentialSignInRequired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnterCredentials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SubmitCredentials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_RedirectSignInRequired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HandleAuthProviderResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PrimaryAuthenticationOutcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_InvalidCredentials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowBadCredentialsMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_InvalidCredentials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_AuthenticationFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowAuthenticationFailedMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_AuthenticationFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_PrimaryAuthenticationSucceeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MfaRequired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_OpenMfaShell</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnterMfa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MfaOutcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_InvalidMfaCode</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowInvalidMfaMessage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_InvalidMfa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_NoMfaRequired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_ValidMfaCode</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RedirectToLandingPage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Success</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="Event_Start" name="Start">
      <bpmn:outgoing>Flow_Start_OpenLoginShell</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:intermediateThrowEvent id="Event_OpenLoginShell" name="Open Login Screen">
      <bpmn:documentation>Journey step J01.JS01. Activate SC01 Login Screen and expose the login baseline.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS01" />
          <camunda:property name="screen_code" value="SC01" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_OpenLoginShell</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenLoginShell_SelectTenant</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:userTask id="Task_SelectTenant" name="Select Tenant">
      <bpmn:documentation>Journey step J01.JS02. User selects the tenant to resolve available authentication methods.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS02" />
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Tenant Selection Step Section" />
          <camunda:property name="ui_element" value="Tenant Registry Searchable Dropdown" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_OpenLoginShell_SelectTenant</bpmn:incoming>
      <bpmn:outgoing>Flow_SelectTenant_TenantSelected</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_LoginShell">
        <bpmn:targetRef>DataObjectReference_LoginShell</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>

    <bpmn:intermediateThrowEvent id="Event_TenantSelected" name="Tenant Selected">
      <bpmn:incoming>Flow_SelectTenant_TenantSelected</bpmn:incoming>
      <bpmn:outgoing>Flow_TenantSelected_ResolveMethods</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:serviceTask id="Task_ResolveTenantAuthMethods" name="Resolve Tenant Authentication Methods">
      <bpmn:documentation>Journey step J01.JS03. Resolve tenant existence, tenant access-state facts, and available authentication methods from Tenant PG Database.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS03" />
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="data_source" value="Tenant PG Database" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_TenantSelected_ResolveMethods</bpmn:incoming>
      <bpmn:outgoing>Flow_ResolveMethods_TenantResolution</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_TenantPgDatabase">
        <bpmn:targetRef>DataStoreReference_TenantPgDatabase</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_TenantResolution" name="Tenant Resolution Outcome">
      <bpmn:incoming>Flow_ResolveMethods_TenantResolution</bpmn:incoming>
      <bpmn:outgoing>Flow_TenantNotFound</bpmn:outgoing>
      <bpmn:outgoing>Flow_TenantSuspended</bpmn:outgoing>
      <bpmn:outgoing>Flow_TenantLicenseExpired</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoAuthMethods</bpmn:outgoing>
      <bpmn:outgoing>Flow_TenantAccessBlocked</bpmn:outgoing>
      <bpmn:outgoing>Flow_AuthMethodsAvailable</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="Event_TenantNotFound" name="Tenant Not Found">
      <bpmn:incoming>Flow_TenantNotFound</bpmn:incoming>
      <bpmn:outgoing>Flow_TenantNotFound_OpenShell</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_OpenTenantNotFoundShell" name="Open Tenant Not Found Screen">
      <bpmn:documentation>Rule-driven outcome. Activate SC03 Tenant Not Found Screen and expose the return path back to login.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC03" />
          <camunda:property name="container" value="Tenant Not Found Section" />
          <camunda:property name="ui_element" value="Back to Login Action" />
          <camunda:property name="rule_outcome" value="TENANT_NOT_FOUND" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_TenantNotFound_OpenShell</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenTenantNotFoundShell_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_TenantNotFound">
      <bpmn:incoming>Flow_OpenTenantNotFoundShell_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_TenantSuspended" name="Tenant Suspended">
      <bpmn:incoming>Flow_TenantSuspended</bpmn:incoming>
      <bpmn:outgoing>Flow_TenantSuspended_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowTenantSuspendedMessage" name="Show Tenant Suspended Message">
      <bpmn:documentation>Rule-driven outcome. Show suspended-tenant feedback in SC01 Login Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Status Message Section" />
          <camunda:property name="ui_element" value="Status Banner" />
          <camunda:property name="rule_outcome" value="TENANT_SUSPENDED" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_TenantSuspended_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowTenantSuspended_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_TenantSuspended">
      <bpmn:incoming>Flow_ShowTenantSuspended_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_TenantLicenseExpired" name="Tenant License Expired">
      <bpmn:incoming>Flow_TenantLicenseExpired</bpmn:incoming>
      <bpmn:outgoing>Flow_TenantLicenseExpired_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowTenantLicenseExpiredMessage" name="Show Tenant License Expired Message">
      <bpmn:documentation>Rule-driven outcome. Show tenant-license-expired feedback in SC01 Login Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Status Message Section" />
          <camunda:property name="ui_element" value="Status Banner" />
          <camunda:property name="rule_outcome" value="TENANT_LICENSE_EXPIRED" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_TenantLicenseExpired_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowTenantLicenseExpired_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_TenantLicenseExpired">
      <bpmn:incoming>Flow_ShowTenantLicenseExpired_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_NoAuthMethods" name="No Authentication Methods">
      <bpmn:incoming>Flow_NoAuthMethods</bpmn:incoming>
      <bpmn:outgoing>Flow_NoAuthMethods_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowNoAuthMethodsMessage" name="Show No Auth Methods Message">
      <bpmn:documentation>Rule-driven outcome. Show the no-auth message inside SC01 Login Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="No Auth Section" />
          <camunda:property name="ui_element" value="No Auth Description" />
          <camunda:property name="rule_outcome" value="NO_AUTH_METHODS" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NoAuthMethods_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowNoAuthMethods_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_NoAuthMethods">
      <bpmn:incoming>Flow_ShowNoAuthMethods_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_TenantAccessBlocked" name="Tenant Access Blocked">
      <bpmn:incoming>Flow_TenantAccessBlocked</bpmn:incoming>
      <bpmn:outgoing>Flow_TenantAccessBlocked_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowTenantAccessBlockedMessage" name="Show Tenant Access Blocked Message">
      <bpmn:documentation>Rule-driven outcome. Show tenant-access-blocked feedback in SC01 Login Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Status Message Section" />
          <camunda:property name="ui_element" value="Status Banner" />
          <camunda:property name="rule_outcome" value="TENANT_ACCESS_BLOCKED" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_TenantAccessBlocked_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowTenantAccessBlocked_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_TenantAccessBlocked">
      <bpmn:incoming>Flow_ShowTenantAccessBlocked_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_AuthMethodsAvailable" name="Authentication Methods Available">
      <bpmn:incoming>Flow_AuthMethodsAvailable</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthMethodsAvailable_SelectMethod</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:userTask id="Task_SelectAuthMethod" name="Select Authentication Provider">
      <bpmn:documentation>Journey step J01.JS04. User selects the required authentication provider.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS04" />
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Provider Selection Section" />
          <camunda:property name="ui_element" value="Provider Header Section" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AuthMethodsAvailable_SelectMethod</bpmn:incoming>
      <bpmn:outgoing>Flow_SelectMethod_ProviderType</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_AuthMethodType" name="Authentication Method Type">
      <bpmn:incoming>Flow_SelectMethod_ProviderType</bpmn:incoming>
      <bpmn:outgoing>Flow_CredentialRequired</bpmn:outgoing>
      <bpmn:outgoing>Flow_RedirectRequired</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="Event_CredentialSignInRequired" name="Credential Sign-In Required">
      <bpmn:incoming>Flow_CredentialRequired</bpmn:incoming>
      <bpmn:outgoing>Flow_CredentialRequired_EnterCredentials</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:userTask id="Task_EnterCredentials" name="Enter Credentials">
      <bpmn:documentation>Journey step J01.JS05. User enters credential-based authentication data.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS05" />
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Provider Variant Section" />
          <camunda:property name="ui_element" value="User Name Input" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CredentialRequired_EnterCredentials</bpmn:incoming>
      <bpmn:outgoing>Flow_EnterCredentials_SubmitCredentials</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_SubmitCredentials" name="Submit Credentials">
      <bpmn:documentation>Journey step J01.JS05. Submit credential sign-in request and resolve primary authentication facts.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS05" />
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="ui_element" value="Sign In Action" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_EnterCredentials_SubmitCredentials</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitCredentials_PrimaryOutcome</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:intermediateThrowEvent id="Event_RedirectSignInRequired" name="Redirect Sign-In Required">
      <bpmn:incoming>Flow_RedirectRequired</bpmn:incoming>
      <bpmn:outgoing>Flow_RedirectRequired_HandleResponse</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:serviceTask id="Task_HandleAuthProviderResponse" name="Handle Authentication Provider Response">
      <bpmn:documentation>Journey step J01.JS05. Receive provider callback/response and resolve primary authentication facts.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS05" />
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="ui_element" value="Sign In Action" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_RedirectRequired_HandleResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_HandleResponse_PrimaryOutcome</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_PrimaryAuthenticationOutcome" name="Primary Authentication Outcome">
      <bpmn:incoming>Flow_SubmitCredentials_PrimaryOutcome</bpmn:incoming>
      <bpmn:incoming>Flow_HandleResponse_PrimaryOutcome</bpmn:incoming>
      <bpmn:outgoing>Flow_InvalidCredentials</bpmn:outgoing>
      <bpmn:outgoing>Flow_AuthenticationFailed</bpmn:outgoing>
      <bpmn:outgoing>Flow_PrimaryAuthenticationSucceeded</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="Event_InvalidCredentials" name="Invalid Credentials">
      <bpmn:incoming>Flow_InvalidCredentials</bpmn:incoming>
      <bpmn:outgoing>Flow_InvalidCredentials_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowBadCredentialsMessage" name="Show Bad Credentials Message">
      <bpmn:documentation>Rule-driven outcome. Show invalid-credentials feedback in SC01 Login Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Status Message Section" />
          <camunda:property name="ui_element" value="Status Banner" />
          <camunda:property name="rule_outcome" value="INVALID_CREDENTIALS" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_InvalidCredentials_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowBadCredentials_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_InvalidCredentials">
      <bpmn:incoming>Flow_ShowBadCredentials_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_AuthenticationFailed" name="Authentication Failed">
      <bpmn:incoming>Flow_AuthenticationFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthenticationFailed_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowAuthenticationFailedMessage" name="Show Authentication Failed Message">
      <bpmn:documentation>Rule-driven outcome. Show generic authentication-failed feedback in SC01 Login Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC01" />
          <camunda:property name="container" value="Status Message Section" />
          <camunda:property name="ui_element" value="Status Banner" />
          <camunda:property name="rule_outcome" value="AUTH_PROVIDER_FAILURE" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AuthenticationFailed_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowAuthenticationFailed_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_AuthenticationFailed">
      <bpmn:incoming>Flow_ShowAuthenticationFailed_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_PrimaryAuthenticationSucceeded" name="Primary Authentication Succeeded">
      <bpmn:incoming>Flow_PrimaryAuthenticationSucceeded</bpmn:incoming>
      <bpmn:outgoing>Flow_PrimaryAuthenticationSucceeded_MfaRequired</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:exclusiveGateway id="Gateway_MfaRequired" name="MFA Required">
      <bpmn:incoming>Flow_PrimaryAuthenticationSucceeded_MfaRequired</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenMfaShell</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoMfaRequired</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="Event_OpenMfaShell" name="Open MFA Screen">
      <bpmn:documentation>Journey step J01.JS06. Activate SC02 MFA Screen when MFA is required after primary authentication succeeds.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS06" />
          <camunda:property name="screen_code" value="SC02" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_OpenMfaShell</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenMfaShell_EnterMfa</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:userTask id="Task_EnterMfa" name="Enter MFA">
      <bpmn:documentation>Journey step J01.JS07. User enters the MFA challenge code.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS07" />
          <camunda:property name="screen_code" value="SC02" />
          <camunda:property name="container" value="Verification Code Section" />
          <camunda:property name="ui_element" value="OTP Digit 1" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_OpenMfaShell_EnterMfa</bpmn:incoming>
      <bpmn:outgoing>Flow_EnterMfa_MfaOutcome</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_MfaOutcome" name="MFA Verification Outcome">
      <bpmn:incoming>Flow_EnterMfa_MfaOutcome</bpmn:incoming>
      <bpmn:outgoing>Flow_InvalidMfaCode</bpmn:outgoing>
      <bpmn:outgoing>Flow_ValidMfaCode</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateThrowEvent id="Event_InvalidMfaCode" name="Invalid MFA Code">
      <bpmn:incoming>Flow_InvalidMfaCode</bpmn:incoming>
      <bpmn:outgoing>Flow_InvalidMfa_ShowMessage</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:sendTask id="Task_ShowInvalidMfaMessage" name="Show Invalid MFA Message">
      <bpmn:documentation>Rule-driven outcome. Show invalid-MFA feedback in SC02 MFA Screen.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="screen_code" value="SC02" />
          <camunda:property name="container" value="Status Message Section" />
          <camunda:property name="ui_element" value="Status Banner" />
          <camunda:property name="rule_outcome" value="INVALID_MFA_CODE" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_InvalidMfa_ShowMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowInvalidMfa_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="End_InvalidMfa">
      <bpmn:incoming>Flow_ShowInvalidMfa_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateThrowEvent id="Event_NoMfaRequired" name="No MFA Required">
      <bpmn:incoming>Flow_NoMfaRequired</bpmn:incoming>
      <bpmn:outgoing>Flow_NoMfaRequired_Redirect</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:intermediateThrowEvent id="Event_ValidMfaCode" name="Valid MFA Code">
      <bpmn:incoming>Flow_ValidMfaCode</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidMfa_Redirect</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>

    <bpmn:serviceTask id="Task_RedirectToLandingPage" name="Redirect To Landing Page">
      <bpmn:documentation>Journey step J01.JS08. Redirect the authenticated user to the system shell and landing page.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="journey_step_code" value="J01.JS08" />
          <camunda:property name="target_shell" value="app-shell-layout" />
          <camunda:property name="target_page" value="Landing Page" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NoMfaRequired_Redirect</bpmn:incoming>
      <bpmn:incoming>Flow_ValidMfa_Redirect</bpmn:incoming>
      <bpmn:outgoing>Flow_RedirectToLandingPage_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_Success">
      <bpmn:incoming>Flow_RedirectToLandingPage_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:dataObjectReference id="DataObjectReference_LoginShell" name="login shell" dataObjectRef="DataObject_LoginShell" />
    <bpmn:dataObject id="DataObject_LoginShell" />
    <bpmn:dataStoreReference id="DataStoreReference_TenantPgDatabase" name="Tenant PG Database" />

    <bpmn:sequenceFlow id="Flow_Start_OpenLoginShell" sourceRef="Event_Start" targetRef="Event_OpenLoginShell" />
    <bpmn:sequenceFlow id="Flow_OpenLoginShell_SelectTenant" sourceRef="Event_OpenLoginShell" targetRef="Task_SelectTenant" />
    <bpmn:sequenceFlow id="Flow_SelectTenant_TenantSelected" sourceRef="Task_SelectTenant" targetRef="Event_TenantSelected" />
    <bpmn:sequenceFlow id="Flow_TenantSelected_ResolveMethods" sourceRef="Event_TenantSelected" targetRef="Task_ResolveTenantAuthMethods" />
    <bpmn:sequenceFlow id="Flow_ResolveMethods_TenantResolution" sourceRef="Task_ResolveTenantAuthMethods" targetRef="Gateway_TenantResolution" />

    <bpmn:sequenceFlow id="Flow_TenantNotFound" sourceRef="Gateway_TenantResolution" targetRef="Event_TenantNotFound">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tenantFound == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_TenantSuspended" sourceRef="Gateway_TenantResolution" targetRef="Event_TenantSuspended">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tenantFound == true &amp;&amp; tenantStatus == 'SUSPENDED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_TenantLicenseExpired" sourceRef="Gateway_TenantResolution" targetRef="Event_TenantLicenseExpired">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tenantFound == true &amp;&amp; tenantLicenseStatus == 'EXPIRED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoAuthMethods" sourceRef="Gateway_TenantResolution" targetRef="Event_NoAuthMethods">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tenantFound == true &amp;&amp; tenantStatus != 'SUSPENDED' &amp;&amp; tenantLicenseStatus != 'EXPIRED' &amp;&amp; !(tenantStatus == 'INACTIVE' || tenantAccessBlocked == true) &amp;&amp; authMethodsCount == 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_TenantAccessBlocked" sourceRef="Gateway_TenantResolution" targetRef="Event_TenantAccessBlocked">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tenantFound == true &amp;&amp; (tenantStatus == 'INACTIVE' || tenantAccessBlocked == true) &amp;&amp; tenantStatus != 'SUSPENDED' &amp;&amp; tenantLicenseStatus != 'EXPIRED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AuthMethodsAvailable" sourceRef="Gateway_TenantResolution" targetRef="Event_AuthMethodsAvailable">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${tenantFound == true &amp;&amp; tenantStatus != 'SUSPENDED' &amp;&amp; tenantLicenseStatus != 'EXPIRED' &amp;&amp; !(tenantStatus == 'INACTIVE' || tenantAccessBlocked == true) &amp;&amp; authMethodsCount &gt; 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_TenantNotFound_OpenShell" sourceRef="Event_TenantNotFound" targetRef="Task_OpenTenantNotFoundShell" />
    <bpmn:sequenceFlow id="Flow_OpenTenantNotFoundShell_End" sourceRef="Task_OpenTenantNotFoundShell" targetRef="End_TenantNotFound" />
    <bpmn:sequenceFlow id="Flow_TenantSuspended_ShowMessage" sourceRef="Event_TenantSuspended" targetRef="Task_ShowTenantSuspendedMessage" />
    <bpmn:sequenceFlow id="Flow_ShowTenantSuspended_End" sourceRef="Task_ShowTenantSuspendedMessage" targetRef="End_TenantSuspended" />
    <bpmn:sequenceFlow id="Flow_TenantLicenseExpired_ShowMessage" sourceRef="Event_TenantLicenseExpired" targetRef="Task_ShowTenantLicenseExpiredMessage" />
    <bpmn:sequenceFlow id="Flow_ShowTenantLicenseExpired_End" sourceRef="Task_ShowTenantLicenseExpiredMessage" targetRef="End_TenantLicenseExpired" />
    <bpmn:sequenceFlow id="Flow_NoAuthMethods_ShowMessage" sourceRef="Event_NoAuthMethods" targetRef="Task_ShowNoAuthMethodsMessage" />
    <bpmn:sequenceFlow id="Flow_ShowNoAuthMethods_End" sourceRef="Task_ShowNoAuthMethodsMessage" targetRef="End_NoAuthMethods" />
    <bpmn:sequenceFlow id="Flow_TenantAccessBlocked_ShowMessage" sourceRef="Event_TenantAccessBlocked" targetRef="Task_ShowTenantAccessBlockedMessage" />
    <bpmn:sequenceFlow id="Flow_ShowTenantAccessBlocked_End" sourceRef="Task_ShowTenantAccessBlockedMessage" targetRef="End_TenantAccessBlocked" />
    <bpmn:sequenceFlow id="Flow_AuthMethodsAvailable_SelectMethod" sourceRef="Event_AuthMethodsAvailable" targetRef="Task_SelectAuthMethod" />
    <bpmn:sequenceFlow id="Flow_SelectMethod_ProviderType" sourceRef="Task_SelectAuthMethod" targetRef="Gateway_AuthMethodType" />

    <bpmn:sequenceFlow id="Flow_CredentialRequired" sourceRef="Gateway_AuthMethodType" targetRef="Event_CredentialSignInRequired">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${selectedAuthMethodType == 'CREDENTIAL'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RedirectRequired" sourceRef="Gateway_AuthMethodType" targetRef="Event_RedirectSignInRequired">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${selectedAuthMethodType == 'REDIRECT'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_CredentialRequired_EnterCredentials" sourceRef="Event_CredentialSignInRequired" targetRef="Task_EnterCredentials" />
    <bpmn:sequenceFlow id="Flow_EnterCredentials_SubmitCredentials" sourceRef="Task_EnterCredentials" targetRef="Task_SubmitCredentials" />
    <bpmn:sequenceFlow id="Flow_SubmitCredentials_PrimaryOutcome" sourceRef="Task_SubmitCredentials" targetRef="Gateway_PrimaryAuthenticationOutcome" />
    <bpmn:sequenceFlow id="Flow_RedirectRequired_HandleResponse" sourceRef="Event_RedirectSignInRequired" targetRef="Task_HandleAuthProviderResponse" />
    <bpmn:sequenceFlow id="Flow_HandleResponse_PrimaryOutcome" sourceRef="Task_HandleAuthProviderResponse" targetRef="Gateway_PrimaryAuthenticationOutcome" />

    <bpmn:sequenceFlow id="Flow_InvalidCredentials" sourceRef="Gateway_PrimaryAuthenticationOutcome" targetRef="Event_InvalidCredentials">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${failureReason == 'INVALID_CREDENTIALS'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AuthenticationFailed" sourceRef="Gateway_PrimaryAuthenticationOutcome" targetRef="Event_AuthenticationFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${loginSucceeded == false &amp;&amp; failureReason != 'INVALID_CREDENTIALS'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PrimaryAuthenticationSucceeded" sourceRef="Gateway_PrimaryAuthenticationOutcome" targetRef="Event_PrimaryAuthenticationSucceeded">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${loginSucceeded == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_InvalidCredentials_ShowMessage" sourceRef="Event_InvalidCredentials" targetRef="Task_ShowBadCredentialsMessage" />
    <bpmn:sequenceFlow id="Flow_ShowBadCredentials_End" sourceRef="Task_ShowBadCredentialsMessage" targetRef="End_InvalidCredentials" />
    <bpmn:sequenceFlow id="Flow_AuthenticationFailed_ShowMessage" sourceRef="Event_AuthenticationFailed" targetRef="Task_ShowAuthenticationFailedMessage" />
    <bpmn:sequenceFlow id="Flow_ShowAuthenticationFailed_End" sourceRef="Task_ShowAuthenticationFailedMessage" targetRef="End_AuthenticationFailed" />
    <bpmn:sequenceFlow id="Flow_PrimaryAuthenticationSucceeded_MfaRequired" sourceRef="Event_PrimaryAuthenticationSucceeded" targetRef="Gateway_MfaRequired" />

    <bpmn:sequenceFlow id="Flow_OpenMfaShell" sourceRef="Gateway_MfaRequired" targetRef="Event_OpenMfaShell">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${mfaRequired == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoMfaRequired" sourceRef="Gateway_MfaRequired" targetRef="Event_NoMfaRequired">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${mfaRequired == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_OpenMfaShell_EnterMfa" sourceRef="Event_OpenMfaShell" targetRef="Task_EnterMfa" />
    <bpmn:sequenceFlow id="Flow_EnterMfa_MfaOutcome" sourceRef="Task_EnterMfa" targetRef="Gateway_MfaOutcome" />
    <bpmn:sequenceFlow id="Flow_InvalidMfaCode" sourceRef="Gateway_MfaOutcome" targetRef="Event_InvalidMfaCode">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${mfaCodeValid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ValidMfaCode" sourceRef="Gateway_MfaOutcome" targetRef="Event_ValidMfaCode">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${mfaCodeValid == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_InvalidMfa_ShowMessage" sourceRef="Event_InvalidMfaCode" targetRef="Task_ShowInvalidMfaMessage" />
    <bpmn:sequenceFlow id="Flow_ShowInvalidMfa_End" sourceRef="Task_ShowInvalidMfaMessage" targetRef="End_InvalidMfa" />
    <bpmn:sequenceFlow id="Flow_NoMfaRequired_Redirect" sourceRef="Event_NoMfaRequired" targetRef="Task_RedirectToLandingPage" />
    <bpmn:sequenceFlow id="Flow_ValidMfa_Redirect" sourceRef="Event_ValidMfaCode" targetRef="Task_RedirectToLandingPage" />
    <bpmn:sequenceFlow id="Flow_RedirectToLandingPage_End" sourceRef="Task_RedirectToLandingPage" targetRef="End_Success" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_AuthenticateUser">
