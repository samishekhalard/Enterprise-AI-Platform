{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance-validation-rules",
  "title": "Governance Validation Rules",
  "description": "Schema for validating agent principle files and governance documents",
  "version": "1.0.0",
  "lastUpdated": "2026-02-25",

  "definitions": {
    "agentPrincipleFile": {
      "type": "object",
      "description": "Structure requirements for agent principle files",
      "required": [
        "version",
        "mandatory",
        "standards",
        "forbidden",
        "checklist",
        "continuousImprovement",
        "changelog"
      ],
      "properties": {
        "version": {
          "type": "object",
          "description": "Version metadata section",
          "required": ["version", "lastUpdated", "changelog"],
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$",
              "description": "Semantic version (e.g., 1.0.0)"
            },
            "lastUpdated": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "ISO date (YYYY-MM-DD)"
            },
            "changelog": {
              "type": "string",
              "description": "Link to changelog section"
            }
          }
        },
        "mandatory": {
          "type": "object",
          "description": "MANDATORY section requirements",
          "required": ["title", "items"],
          "properties": {
            "title": {
              "type": "string",
              "const": "MANDATORY (Read Before Any Work)"
            },
            "items": {
              "type": "array",
              "minItems": 5,
              "maxItems": 15,
              "description": "5-15 mandatory rules"
            }
          }
        },
        "standards": {
          "type": "object",
          "description": "Standards section requirements",
          "required": ["title", "items"],
          "properties": {
            "title": {
              "type": "string",
              "const": "Standards"
            },
            "items": {
              "type": "array",
              "minItems": 10,
              "description": "At least 10 domain-specific standards"
            }
          }
        },
        "forbidden": {
          "type": "object",
          "description": "Forbidden Practices section",
          "required": ["title", "items"],
          "properties": {
            "title": {
              "type": "string",
              "const": "Forbidden Practices"
            },
            "items": {
              "type": "array",
              "minItems": 5,
              "description": "At least 5 forbidden practices"
            }
          }
        },
        "checklist": {
          "type": "object",
          "description": "Checklist Before Completion section",
          "required": ["title", "items"],
          "properties": {
            "title": {
              "type": "string",
              "const": "Checklist Before Completion"
            },
            "items": {
              "type": "array",
              "minItems": 5,
              "maxItems": 20,
              "description": "5-20 checklist items with [ ] markers"
            }
          }
        },
        "continuousImprovement": {
          "type": "object",
          "description": "Continuous Improvement section",
          "required": ["howToSuggest", "feedbackLog"],
          "properties": {
            "howToSuggest": {
              "type": "object",
              "description": "Process for suggesting improvements"
            },
            "feedbackLog": {
              "type": "object",
              "description": "Table for tracking suggestions"
            }
          }
        },
        "changelog": {
          "type": "object",
          "description": "Changelog section",
          "required": ["entries"],
          "properties": {
            "entries": {
              "type": "array",
              "minItems": 1,
              "description": "At least one changelog entry"
            }
          }
        }
      }
    },

    "checklistFile": {
      "type": "object",
      "description": "Structure requirements for checklist files",
      "required": ["version", "purpose", "items"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "purpose": {
          "type": "string",
          "minLength": 10
        },
        "items": {
          "type": "array",
          "minItems": 5,
          "description": "At least 5 checklist items"
        }
      }
    },

    "governanceFramework": {
      "type": "object",
      "description": "Structure requirements for governance framework",
      "required": [
        "version",
        "executiveSummary",
        "principles",
        "agentLifecycle",
        "crossAgentWorkflows",
        "enforcement",
        "checklists",
        "traceability",
        "continuousImprovement"
      ]
    }
  },

  "validationRules": {
    "principleFiles": {
      "description": "Rules for validating agent principle files",
      "requiredFiles": [
        "ARCH-PRINCIPLES.md",
        "SA-PRINCIPLES.md",
        "BA-PRINCIPLES.md",
        "DEV-PRINCIPLES.md",
        "DBA-PRINCIPLES.md",
        "QA-PRINCIPLES.md",
        "SEC-PRINCIPLES.md",
        "DEVOPS-PRINCIPLES.md",
        "DOC-PRINCIPLES.md"
      ],
      "requiredSections": [
        "## Version",
        "## MANDATORY (Read Before Any Work)",
        "## Standards",
        "## Forbidden Practices",
        "## Checklist Before Completion",
        "## Continuous Improvement",
        "## Changelog"
      ],
      "sectionMinimums": {
        "MANDATORY": 5,
        "Standards": 10,
        "Forbidden": 5,
        "Checklist": 5
      }
    },

    "checklistFiles": {
      "description": "Rules for validating checklist files",
      "requiredFiles": [
        "pre-commit-checklist.md",
        "design-review-checklist.md",
        "release-checklist.md"
      ],
      "requiredSections": [
        "## Version",
        "## Quick Reference"
      ],
      "checkboxPattern": "^- \\[ \\]"
    },

    "frameworkFile": {
      "description": "Rules for governance framework",
      "requiredSections": [
        "## 1. Executive Summary",
        "## 2. Governance Principles",
        "## 3. Agent Lifecycle Protocol",
        "## 4. Cross-Agent Workflows",
        "## 5. Enforcement Mechanisms"
      ]
    },

    "versionFormat": {
      "pattern": "^v?\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic versioning (X.Y.Z or vX.Y.Z)"
    },

    "dateFormat": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date (YYYY-MM-DD)"
    }
  },

  "complianceMetrics": {
    "description": "Metrics for governance compliance",
    "targets": {
      "principleCompliance": {
        "description": "Percentage of agent outputs following principles",
        "target": 95,
        "unit": "percent"
      },
      "violationRate": {
        "description": "Principle violations per sprint",
        "target": 5,
        "comparison": "lessThan",
        "unit": "count"
      },
      "improvementRate": {
        "description": "Percentage of suggestions implemented",
        "target": 50,
        "unit": "percent"
      },
      "documentationCoverage": {
        "description": "Percentage of features documented",
        "target": 100,
        "unit": "percent"
      }
    }
  },

  "errorMessages": {
    "missingFile": "Required file not found: {filename}",
    "missingSection": "Required section not found: {section} in {filename}",
    "insufficientItems": "Section {section} requires at least {minimum} items, found {actual}",
    "invalidVersion": "Version format invalid: {version}. Expected: X.Y.Z",
    "invalidDate": "Date format invalid: {date}. Expected: YYYY-MM-DD",
    "missingCheckbox": "Checklist item missing checkbox marker: {item}"
  }
}
